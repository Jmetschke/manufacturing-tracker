TURSO_DATABASE_URL=
TURSO_DATABASE_TOKEN=

# Optional: use a separate Turso database for calendar data.
TURSO_CALENDAR_URL=
TURSO_CALENDAR_TOKEN=

# Local/offline development only. Leave unset in production.
# ALLOW_LOCAL_SQLITE=true

# Optional path for npm run backup:sqlite-to-turso.
# SQLITE_BACKUP_SOURCE=./data/database.sqlite
